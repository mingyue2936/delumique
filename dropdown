{% if product != blank and product.metafields.custom.sibling_products != blank %}
  {% assign current_scent = product.metafields.custom.scent_name.value | default: product.title %}

  <style>
    .tm-scent-selector,
    .tm-scent-selector *,
    .tm-scent-selector *::before,
    .tm-scent-selector *::after {
      box-sizing: border-box;
      font-family: inherit;
    }

    .tm-scent-selector {
      position: relative;
      width: 100%;
      margin: 0 0 16.5px;
      color: inherit;
      font: inherit;
    }

    .tm-scent-dropdown {
      position: relative;
      width: 100%;
      margin: 0;
      color: inherit;
      font: inherit;
    }

    /* ขนาดเดียวกับ Size dropdown */
    .tm-scent-dropdown > summary {
      position: relative;
      width: 100%;
      height: 50px !important;
      min-height: 50px !important;
      margin: 0;
      padding: 6px 42px 6px 16px !important;

      border: 1px solid rgba(0, 0, 0, 0.14);
      border-radius: 0;
      background: transparent;
      color: inherit;
      cursor: pointer;
      list-style: none;

      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;

      font-family: inherit;
      font-size: inherit;
      font-weight: inherit;
      font-style: inherit;
      line-height: inherit;
      letter-spacing: inherit;
      text-transform: none;
    }

    .tm-scent-dropdown > summary::-webkit-details-marker {
      display: none;
    }

    .tm-scent-dropdown > summary::marker {
      content: "";
      display: none;
    }

    .tm-scent-label {
      display: block;
      margin: 0 0 2px;
      padding: 0;
      color: inherit;

      font-family: inherit;
      font-size: 0.72em;
      font-weight: inherit;
      font-style: inherit;
      line-height: 1;
      letter-spacing: inherit;
      text-transform: none;
    }

    .tm-scent-current {
      display: block;
      margin: 0;
      padding: 0;
      color: inherit;

      font-family: inherit;
      font-size: inherit;
      font-weight: inherit;
      font-style: inherit;
      line-height: 1.05;
      letter-spacing: inherit;
      text-transform: none;
    }

    /* ลูกศรขนาดเดียวกับ Size: 6.49 × 4px */
    .tm-scent-arrow {
      position: absolute;
      top: 50%;
      right: 18px;

      width: 6.49px;
      height: 4px;

      display: flex;
      align-items: center;
      justify-content: center;

      color: inherit;
      transform: translateY(-50%);
      transform-origin: center;
      transition: transform 0.2s ease;
      pointer-events: none;
    }

    .tm-scent-arrow svg {
      display: block;
      width: 6.49px;
      height: 4px;
      overflow: visible;
    }

    .tm-scent-dropdown[open] .tm-scent-arrow {
      transform: translateY(-50%) rotate(180deg);
    }

    .tm-scent-options {
      position: absolute;
      top: calc(100% + 4px);
      left: 0;
      z-index: 999;

      width: 100%;
      max-height: 300px;
      margin: 0;
      padding: 0;
      overflow-y: auto;

      border: 1px solid rgba(0, 0, 0, 0.14);
      border-radius: 0;
      background: rgb(var(--color-background, 255 255 255));
      box-shadow: none;
      list-style: none;

      color: inherit;
      font: inherit;
    }

    .tm-scent-option {
      position: relative;
      width: 100%;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .tm-scent-option-link,
    .tm-scent-option-current {
      position: relative;
      width: 100%;
      height: 50px;
      min-height: 50px;
      margin: 0;
      padding: 6px 42px 6px 16px;

      border: 0;
      background: transparent;
      color: inherit;
      text-decoration: none;

      display: flex;
      align-items: center;

      font-family: inherit;
      font-size: inherit;
      font-weight: inherit;
      font-style: inherit;
      line-height: inherit;
      letter-spacing: inherit;
      text-transform: none;
    }

    .tm-scent-option-link {
      cursor: pointer;
    }

    .tm-scent-option-link:hover,
    .tm-scent-option-link:focus-visible {
      background: rgba(0, 0, 0, 0.035);
      color: inherit;
      text-decoration: none;
    }

    .tm-scent-option-current {
      cursor: default;
    }

    .tm-scent-option:not(.is-current) {
      opacity: 0.58;
    }

    .tm-scent-check {
      position: absolute;
      top: 50%;
      right: 18px;

      width: 13px;
      height: 7px;

      border-left: 1.5px solid currentColor;
      border-bottom: 1.5px solid currentColor;

      transform: translateY(-70%) rotate(-45deg);
      pointer-events: none;
    }
  </style>

  <div class="tm-scent-selector">
    <details class="tm-scent-dropdown">
      <summary aria-label="Select scent">
        <span class="tm-scent-label">
          scent
        </span>

        <span class="tm-scent-current">
          {{ current_scent }}
        </span>

        <span class="tm-scent-arrow" aria-hidden="true">
          <svg
            viewBox="0 0 6.49 4"
            width="6.49"
            height="4"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M0.45 0.45L3.245 3.35L6.04 0.45"
              stroke="currentColor"
              stroke-width="0.9"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </span>
      </summary>

      <ul class="tm-scent-options" role="list">
        {% for sibling in product.metafields.custom.sibling_products.value %}
          {% assign sibling_scent = sibling.metafields.custom.scent_name.value | default: sibling.title %}

          {% if sibling.handle == product.handle %}
            <li class="tm-scent-option is-current">
              <span
                class="tm-scent-option-current"
                aria-current="true"
              >
                {{ sibling_scent }}

                <span
                  class="tm-scent-check"
                  aria-hidden="true"
                ></span>
              </span>
            </li>
          {% else %}
            <li class="tm-scent-option">
              <a
                class="tm-scent-option-link"
                href="{{ sibling.url }}"
              >
                {{ sibling_scent }}
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </details>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const scentDropdowns =
        document.querySelectorAll('.tm-scent-dropdown');

      scentDropdowns.forEach(function (dropdown) {
        dropdown.addEventListener('toggle', function () {
          if (!dropdown.open) return;

          scentDropdowns.forEach(function (otherDropdown) {
            if (otherDropdown !== dropdown) {
              otherDropdown.removeAttribute('open');
            }
          });
        });
      });

      document.addEventListener('click', function (event) {
        scentDropdowns.forEach(function (dropdown) {
          if (!dropdown.contains(event.target)) {
            dropdown.removeAttribute('open');
          }
        });
      });

      document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') {
          scentDropdowns.forEach(function (dropdown) {
            dropdown.removeAttribute('open');
          });
        }
      });
    });
  </script>
{% endif %}
